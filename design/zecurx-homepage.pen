                    { "type": "text", "id": "cp1", "content": "Start Protecting Now →", "fontSize": 14, "fontWeight": "600", "fontFamily": "Manrope", "fill": "$--primary-foreground" }
                  ]
                },
                {
                  "type": "frame",
                  "id": "cta-secondary",
                  "name": "Talk to Experts",
                  "cornerRadius": 999,
                  "stroke": { "align": "inside", "thickness": 1, "fill": "$--border" },
                  "padding": [14, 28],
                  "children": [
                    { "type": "text", "id": "cs1", "content": "Talk to Experts", "fontSize": 14, "fontWeight": "500", "fontFamily": "Manrope", "fill": "$--foreground" }
                  ]
                }
              ]
            },
            {
              "type": "text",
              "id": "hero-trust",
              "name": "Trust Line",
              "content": "Trusted by security teams at fast-growing Indian startups",
              "fontSize": 13,
              "fontWeight": "400",
              "fontFamily": "Manrope",
              "fill": "$--muted-foreground"
            }
          ]
        },
        {
          "type": "frame",
          "id": "hero-right",
          "name": "Hero Visual",
          "width": 560,
          "height": 480,
          "cornerRadius": 20,
          "fill": "$--accent",
          "stroke": { "align": "inside", "thickness": 1, "fill": "$--border" },
          "layout": "vertical",
          "justifyContent": "center",
          "alignItems": "center",
          "children": [
            { "type": "text", "id": "hv1", "content": "Security Platform Visual", "fontSize": 16, "fontWeight": "500", "fontFamily": "Manrope", "fill": "$--muted-foreground" }
          ]
        }
      ]
    },
