{
  "version": "2.6",
  "themes": {
    "Mode": ["Light", "Dark"]
  },
  "variables": {
    "--background": {
      "type": "color",
      "value": [
        { "value": "#FAFBFC" },
        { "value": "#0A0B0F", "theme": { "Mode": "Dark" } }
      ]
    },
    "--foreground": {
      "type": "color",
      "value": [
        { "value": "#1A1D2E" },
        { "value": "#F0F1F3", "theme": { "Mode": "Dark" } }
      ]
    },
    "--card": {
      "type": "color",
      "value": [
        { "value": "#FFFFFF" },
        { "value": "#141520", "theme": { "Mode": "Dark" } }
      ]
    },
    "--card-foreground": {
      "type": "color",
      "value": [
        { "value": "#1A1D2E" },
        { "value": "#F0F1F3", "theme": { "Mode": "Dark" } }
      ]
    },
    "--primary": {
      "type": "color",
      "value": [
        { "value": "#4A6CF7" },
        { "value": "#5B7BF7", "theme": { "Mode": "Dark" } }
      ]
    },
    "--primary-foreground": {
      "type": "color",
      "value": [
        { "value": "#FFFFFF" },
        { "value": "#FFFFFF", "theme": { "Mode": "Dark" } }
      ]
    },
    "--muted": {
      "type": "color",
      "value": [
        { "value": "#F0F1F3" },
        { "value": "#1E1F2B", "theme": { "Mode": "Dark" } }
      ]
    },
    "--muted-foreground": {
      "type": "color",
      "value": [
        { "value": "#6B7080" },
        { "value": "#8B8FA0", "theme": { "Mode": "Dark" } }
      ]
    },
    "--border": {
      "type": "color",
      "value": [
        { "value": "#E2E4E8" },
        { "value": "#2A2C3A", "theme": { "Mode": "Dark" } }
      ]
    },
    "--accent": {
      "type": "color",
      "value": [
        { "value": "#EDEFF2" },
        { "value": "#1E1F2B", "theme": { "Mode": "Dark" } }
      ]
    },
    "--font-primary": {
      "type": "string",
      "value": [{ "value": "Manrope" }]
    },
    "--font-display": {
      "type": "string",
      "value": [{ "value": "Newsreader" }]
    },
    "--radius": {
      "type": "number",
      "value": [{ "value": 10 }]
    },
    "--radius-pill": {
      "type": "number",
      "value": [{ "value": 999 }]
    }
  },
  "children": [
    {
      "type": "frame",
      "id": "nav-01",
      "x": 0,
      "y": 0,
      "name": "Navbar",
      "clip": true,
      "width": 1440,
      "height": 72,
      "fill": "$--background",
      "stroke": { "align": "inside", "thickness": 1, "fill": "$--border" },
      "layout": "horizontal",
      "padding": [0, 48],
      "alignItems": "center",
      "justifyContent": "space-between",
      "children": [
        {
          "type": "text",
          "id": "nav-logo",
          "name": "Logo",
          "content": "ZecurX",
          "fontSize": 22,
          "fontWeight": "700",
          "fontFamily": "Manrope",
          "fill": "$--foreground",
          "letterSpacing": -0.5
        },
        {
          "type": "frame",
          "id": "nav-links",
          "name": "Nav Links",
          "layout": "horizontal",
          "gap": 32,
          "alignItems": "center",
          "children": [
            { "type": "text", "id": "nl1", "content": "Services", "fontSize": 14, "fontWeight": "500", "fontFamily": "Manrope", "fill": "$--muted-foreground" },
            { "type": "text", "id": "nl2", "content": "Solutions", "fontSize": 14, "fontWeight": "500", "fontFamily": "Manrope", "fill": "$--muted-foreground" },
            { "type": "text", "id": "nl3", "content": "Industries", "fontSize": 14, "fontWeight": "500", "fontFamily": "Manrope", "fill": "$--muted-foreground" },
            { "type": "text", "id": "nl4", "content": "About", "fontSize": 14, "fontWeight": "500", "fontFamily": "Manrope", "fill": "$--muted-foreground" },
            { "type": "text", "id": "nl5", "content": "Blog", "fontSize": 14, "fontWeight": "500", "fontFamily": "Manrope", "fill": "$--muted-foreground" }
          ]
        },
        {
          "type": "frame",
          "id": "nav-ctas",
          "name": "Nav CTAs",
          "layout": "horizontal",
          "gap": 12,
          "alignItems": "center",
          "children": [
            {
              "type": "frame",
              "id": "nav-btn-contact",
              "name": "Contact Button",
              "cornerRadius": 999,
              "fill": "$--primary",
              "padding": [10, 20],
              "children": [
                { "type": "text", "id": "nb1", "content": "Get in Touch", "fontSize": 13, "fontWeight": "600", "fontFamily": "Manrope", "fill": "$--primary-foreground" }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "frame",
      "id": "hero-section",
      "x": 0,
      "y": 72,
      "name": "Hero",
      "clip": true,
      "width": 1440,
      "height": 720,
      "fill": "$--background",
      "layout": "horizontal",
      "padding": [120, 80],
      "gap": 64,
      "alignItems": "center",
      "children": [
        {
          "type": "frame",
          "id": "hero-left",
          "name": "Hero Content",
          "layout": "vertical",
          "gap": 24,
          "width": 620,
          "children": [
            {
              "type": "frame",
              "id": "hero-pill",
              "name": "Pill Label",
              "cornerRadius": 999,
              "stroke": { "align": "inside", "thickness": 1, "fill": "$--border" },
              "padding": [6, 16],
              "children": [
                { "type": "text", "id": "hp1", "content": "Enterprise Security for Modern Teams", "fontSize": 12, "fontWeight": "500", "fontFamily": "Manrope", "fill": "$--muted-foreground", "letterSpacing": 0.5 }
