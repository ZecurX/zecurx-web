            {
              "type": "text",
              "id": "hero-sub",
              "name": "Subtitle",
              "content": "ZecurX delivers enterprise-grade application security, cloud protection, and compliance — purpose-built for startups and modern engineering teams.",
              "fontSize": 18,
              "fontWeight": "400",
              "fontFamily": "Manrope",
              "fill": "$--muted-foreground",
              "lineHeight": 1.6,
              "textGrowth": "fixed-width",
              "width": 520
