# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/zecurx

# Authentication & Security
JWT_SECRET=your-secret-key-minimum-32-characters-long
ADMIN_PASSWORD=your-secure-admin-password

# Application URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_CDN_URL=https://your-cdn-url.com

# Development Mode (set to "true" for development features)
NEXT_PUBLIC_DEV_MODE=false

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx

# Email Services
RESEND_API_KEY=re_xxxxxxxxxxxxx
SENDGRID_API_KEY=SG.xxxxxxxxxxxxx

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your-email@example.com
SMTP_PASSWORD=your-email-password
SMTP_OFFICIAL_EMAIL=official@zecurx.com
SMTP_OFFICIAL_PASSWORD=official-email-password

# Google Sheets Integration (for forms, etc.)
GOOGLE_SHEET_ID=your-google-sheet-id
GOOGLE_SHEETS_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Object Storage - Hetzner S3
HETZNER_S3_ENDPOINT=https://fsn1.your-objectstorage.com
HETZNER_S3_BUCKET=your-bucket-name
HETZNER_S3_ACCESS_KEY=your-access-key
HETZNER_S3_SECRET_KEY=your-secret-key

# Object Storage - Linode S3
LINODE_S3_ENDPOINT=https://us-east-1.linodeobjects.com
LINODE_S3_BUCKET=your-bucket-name
LINODE_S3_ACCESS_KEY=your-access-key
LINODE_S3_SECRET_KEY=your-secret-key

# ZecurX API (if using external API)
ZECURX_API_URL=https://api.zecurx.com
ZECURX_API_KEY=your-api-key

# Rate Limiting (Upstash Redis) - REQUIRED IN PRODUCTION
# UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Vercel Environment Variables (auto-populated by Vercel)
# VERCEL=1
# VERCEL_ENV=production
# VERCEL_URL=your-app.vercel.app
# VERCEL_GIT_COMMIT_SHA=abc123
# VERCEL_GIT_COMMIT_REF=main
# VERCEL_GIT_COMMIT_MESSAGE="Your commit message"
# VERCEL_GIT_REPO_OWNER=your-username
# VERCEL_GIT_REPO_SLUG=your-repo
